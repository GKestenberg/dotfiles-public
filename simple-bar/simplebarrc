  "customStyles": {
    "styles": "/* Custom styles to match sketchybar theme */\n.simple-bar {\n  background-color: #000000 !important;\n  height: 32px !important;\n  color: #e2e2e3 !important;\n}\n\n.simple-bar--spaces {\n  background-color: #000000 !important;\n  height: 32px !important;\n}\n\n.simple-bar--data {\n  height: 32px !important;\n  color: #e2e2e3 !important;\n}\n\n.time {\n  margin-right: 10px !important;\n}\n\n/* Spaces - default state */\n.space__inner {\n  background-color: #000000 !important;\n  border: 1px solid #7f8490 !important;\n  border-radius: 4px !important;\n  color: #e2e2e3 !important;\n  box-shadow: none !important;\n}\n\n/* Spaces - focused state */\n.space--focused .space__inner {\n  background-color: #000000 !important;\n  border: 1px solid #ffffff !important;\n  color: #e2e2e3 !important;\n}\n\n/* Data widgets */\n.data-widget {\n  background-color: #000000 !important;\n  border: 1px solid #7f8490 !important;\n  border-radius: 4px !important;\n  color: #e2e2e3 !important;\n}\n\n/* Process widget */\n.process__window {\n  background-color: #000000 !important;\n  border: 1px solid #7f8490 !important;\n  border-radius: 4px !important;\n  color: #e2e2e3 !important;\n  box-shadow: none !important;\n}\n\n/* Process focused state */\n.process__window--focused {\n  background-color: #000000 !important;\n  border: 1px solid #ffffff !important;\n  color: #e2e2e3 !important;\n}\n\n/* White text/icons for all data widgets */\n.simple-bar--data * {\n  color: #e2e2e3 !important;\n  fill: #e2e2e3 !important;\n}\n\n/* Space icons */\n.space__icon {\n  fill: #e2e2e3 !important;\n  opacity: 0.7 !important;\n}\n\n.space--focused .space__icon {\n  opacity: 1 !important;\n}"
  },
